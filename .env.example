# Polymarket Maker Bot 环境变量配置
# 复制此文件为 .env 并填写实际值

# ==================== 钱包配置 ====================
# 你的Polymarket钱包私钥（非常重要！不要泄露！）
POLYMARKET_PRIVATE_KEY=your_private_key_here

# 你的钱包地址
POLYMARKET_WALLET_ADDRESS=0xYourWalletAddressHere

# ==================== API配置 ====================
# Polymarket API密钥（如果需要）
POLYMARKET_API_KEY=

# Binance API密钥（用于获取价格数据）
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ==================== 网络配置 ====================
# RPC节点URL（Polygon网络）
POLYGON_RPC_URL=https://polygon-rpc.com

# 代理配置（如果需要）
HTTP_PROXY=
HTTPS_PROXY=

# ==================== 交易配置 ====================
# 最大仓位（美元）
MAX_POSITION_SIZE=1000

# 每日最大亏损（美元）
MAX_DAILY_LOSS=100

# 默认订单大小（合约数量）
DEFAULT_ORDER_SIZE=100

# ==================== 策略配置 ====================
# 启用5分钟市场策略
ENABLE_5MIN_STRATEGY=true

# 启用做市策略
ENABLE_MARKET_MAKING=true

# T-10秒执行
T_MINUS_SECONDS=10

# ==================== 性能配置 ====================
# 目标延迟（毫秒）
TARGET_LATENCY_MS=100

# 最大可接受延迟（毫秒）
MAX_LATENCY_MS=200

# ==================== 日志配置 ====================
# 日志级别
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=polymarket_maker.log

# ==================== 测试模式 ====================
# 启用模拟交易（不实际下单）
PAPER_TRADING=true

# 模拟初始余额（美元）
SIMULATED_BALANCE=1000

# ==================== 报警配置 ====================
# Telegram报警机器人令牌
TELEGRAM_BOT_TOKEN=

# Telegram聊天ID
TELEGRAM_CHAT_ID=

# 启用延迟报警
ENABLE_LATENCY_ALERTS=true

# 启用错误报警
ENABLE_ERROR_ALERTS=true

# ==================== 自我优化配置 ====================
# 启用自我优化
ENABLE_SELF_OPTIMIZATION=true

# 学习率
LEARNING_RATE=0.1

# 探索率
EXPLORATION_RATE=0.05

# ==================== 数据库配置 ====================
# 数据库类型
DB_TYPE=sqlite

# 数据库路径
DB_PATH=polymarket_bot.db

# ==================== 其他配置 ====================
# 运行模式：development, testing, production
RUN_MODE=development

# 时区
TIMEZONE=Asia/Shanghai